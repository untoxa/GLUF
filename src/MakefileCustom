# rules for the binaries
BIN2C = python ../tools/bin2c/bin2c.py

DATAS = $(foreach dir,../res/data,$(notdir $(wildcard $(dir)/*.bin)))

OBJS := $(DATAS:%.bin=$(OBJDIR_RES)/%.o) $(OBJS)
SEC_TARGETS := $(DATAS:%.bin=$(OBJDIR_RES)/%.c) $(SEC_TARGETS)

.SECONDEXPANSION:
$(OBJDIR_RES)/%.c: ../res/data/%.bin $$(wildcard ../res/data/%.bin.meta)
	@$(BIN2C) -o $@ $(if $(wildcard $<.meta),`cat <$<.meta`) $<
