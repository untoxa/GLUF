# this file contains specific rules for some specific assets which are used in this game,
# but not supported by the CrossZGB itself. CrossZGB Makefile system includes this file
# and everything get built together at once

# there are three sections for the different types of the custom assets:
# 1. the background tiles - i had to go with the custom tool, because the order of tiles
#    which are loaded into VRAM is important for the efficient parallax implementation
# 2. the level data - those levels were taken from the original game assets provided by
#    Denis Grachev, they are in the binary format
# 3. the parallax tiles - specific data for the "slower scrolling background" effect,
#    it is produced from the same graphics assets, which are used in (1)

# ------------------------------
# rules for the background tiles
PNG2METATILES = python ../tools/png2metatiles/png2metatiles.py

METATILES = $(foreach dir,../res/metatiles/$(EXT),$(notdir $(wildcard $(dir)/*.png)))

OBJS := $(METATILES:%.png=$(OBJDIR_RES)/%.o) $(OBJS)
SEC_TARGETS := $(METATILES:%.png=$(OBJDIR_RES)/%.c) $(SEC_TARGETS)

.SECONDEXPANSION:
$(OBJDIR_RES)/%.c: ../res/metatiles/$(EXT)/%.png $$(wildcard ../res/metatiles/$(EXT)/%.png.meta)
	@$(PNG2METATILES) -o $@ $(if $(wildcard $<.meta),`cat <$<.meta`) $<

# ------------------------------
# rules for the binary files with the level data
BIN2C = python ../tools/bin2c/bin2c.py
GBCOMPRESS = $(GBDK_HOME_UNIX)/bin/gbcompress

DATAS = $(foreach dir,../res/data,$(notdir $(wildcard $(dir)/*.bin)))

OBJS := $(DATAS:%.bin=$(OBJDIR_RES)/%.o) $(OBJS)
SEC_TARGETS := $(DATAS:%.bin=$(OBJDIR_RES)/%.c) $(SEC_TARGETS)

.SECONDEXPANSION:
$(OBJDIR_RES)/%.c: ../res/data/%.bin $$(wildcard ../res/data/%.bin.meta)
	@$(GBCOMPRESS) --alg=zx0 $< $(basename $@).zx0
	@$(BIN2C) -i $(basename $(notdir $<)) -o $@ $(if $(wildcard $<.meta),`cat <$<.meta`) $(basename $@).zx0

# ------------------------------
# rules for the parallax tiles
PNG2PARALLAX = python ../tools/parallax/parallax.py

PARALLAXTILES = $(foreach dir,../res/parallax/$(EXT),$(notdir $(wildcard $(dir)/*.parallax)))

OBJS := $(PARALLAXTILES:%.parallax=$(OBJDIR_RES)/parallax_%.o) $(OBJS)
SEC_TARGETS := $(PARALLAXTILES:%.parallax=$(OBJDIR_RES)/parallax_%.c) $(SEC_TARGETS)

.SECONDEXPANSION:
$(OBJDIR_RES)/parallax_%.c: ../res/parallax/$(EXT)/%.parallax $$(wildcard ../res/parallax/$(EXT)/%.parallax.meta)
	@$(PNG2PARALLAX) -s ../res/metatiles/$(EXT)/$(basename $(notdir $<)).png -o $@ $(if $(wildcard $<.meta),`cat <$<.meta`) -i parallax_$(basename $(notdir $<))
