# this file contains specific rules for some specific assets which are used in this game,
# but not supported by the CrossZGB itself. CrossZGB Makefile system includes this file
# and everything get built together at once

# rules for the binary files with the level data
BIN2C = python ../tools/bin2c/bin2c.py
GBCOMPRESS = $(GBDK_HOME_UNIX)/bin/gbcompress

DATAS = $(foreach dir,../res/data,$(notdir $(wildcard $(dir)/*.bin)))

OBJS := $(DATAS:%.bin=$(OBJDIR_RES)/%.o) $(OBJS)
SEC_TARGETS := $(DATAS:%.bin=$(OBJDIR_RES)/%.c) $(SEC_TARGETS)

.SECONDEXPANSION:
$(OBJDIR_RES)/%.c: ../res/data/%.bin $$(wildcard ../res/data/%.bin.meta)
	@$(GBCOMPRESS) --alg=zx0 $< $(basename $@).zx0
	@$(BIN2C) -i $(basename $(notdir $<)) -o $@ $(if $(wildcard $<.meta),`cat <$<.meta`) $(basename $@).zx0

# rules for the parallax tiles
PNG2PARALLAX = python ../tools/parallax/parallax.py

PARALLAXTILES = $(foreach dir,../res/parallax/$(EXT),$(notdir $(wildcard $(dir)/*.parallax)))

OBJS := $(PARALLAXTILES:%.parallax=$(OBJDIR_RES)/parallax_%.o) $(OBJS)
SEC_TARGETS := $(PARALLAXTILES:%.parallax=$(OBJDIR_RES)/parallax_%.c) $(SEC_TARGETS)

.SECONDEXPANSION:
$(OBJDIR_RES)/parallax_%.c: ../res/parallax/$(EXT)/%.parallax $$(wildcard ../res/parallax/$(EXT)/%.parallax.meta)
	@$(PNG2PARALLAX) -s ../res/backgrounds/$(EXT)/$(basename $(notdir $<)).png -o $@ $(if $(wildcard $<.meta),`cat <$<.meta`) -i parallax_$(basename $(notdir $<))
